---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE_URL, createMetadata } from "@/lib/seo";
import { buildBreadcrumbSchema } from "@/lib/schema";

const title = "ToolBite Guides & Tutorials — Complete Guide | ToolBite";
const description =
  "Browse JSON, JWT, SEO, Base64, UUID, URL, password, and image guides linked to ToolBite tools. Step-by-step tutorials with examples. Free on ToolBite.";
const canonicalPath = "/guides/index.html";
const metadata = createMetadata({
  title,
  description,
  canonicalPath,
  keywords: ["ToolBite guides", "JSON guide", "JWT tutorial", "SEO slug guide", "developer tutorials"]
});
const pageUrl = `${SITE_URL}${canonicalPath}`;
const schemas = [
  buildBreadcrumbSchema([
    { name: "Home", url: SITE_URL },
    { name: "Guides", url: pageUrl }
  ])
];
const mainHtml = String.raw`<main id="main-content" class="flex-grow max-w-7xl mx-auto px-4 py-10 w-full">
    <nav class="tb-breadcrumb text-sm text-gray-500 mb-6" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2">
        <li><a href="../" class="hover:text-blue-600 transition">Home</a></li>
        <li>›</li>
        <li class="text-gray-800 dark:text-gray-200 font-medium">Guides</li>
      </ol>
    </nav>

    <div class="mb-8">
      <h1 class="text-4xl font-extrabold text-gray-900 dark:text-gray-100 mb-2" data-pseo-target="h1">ToolBite guides & tutorials</h1>
      <p class="text-lg text-gray-600 dark:text-gray-400 max-w-3xl">Practical tutorials for JSON, JWT, SEO slugs, and other browser-based workflows that connect directly to ToolBite tools.</p>
    </div>

    <section class="tb-card mb-8 md:p-8 dark:text-gray-100" aria-labelledby="guides-start-title">
      <h2 id="guides-start-title" class="text-xl font-bold mb-4 text-gray-900 dark:text-white">Start with a workflow</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <a href="/categories/developer-tools.html" class="tb-card tb-card-soft tb-card-pad-sm">
          <h3 class="font-bold mb-2 text-gray-900 dark:text-white">Developer tools</h3>
          <p class="text-sm text-gray-900 dark:text-gray-100">JSON formatting, JWT decoding, Base64, hashing, and other debugging helpers.</p>
        </a>
        <a href="/categories/seo-tools.html" class="tb-card tb-card-soft tb-card-pad-sm">
          <h3 class="font-bold mb-2 text-gray-900 dark:text-white">SEO workflows</h3>
          <p class="text-sm text-gray-900 dark:text-gray-100">Slug creation, read time, structured data cleanup, and content packaging tasks.</p>
        </a>
        <a href="/categories/text-tools.html" class="tb-card tb-card-soft tb-card-pad-sm">
          <h3 class="font-bold mb-2 text-gray-900 dark:text-white">Text cleanup</h3>
          <p class="text-sm text-gray-900 dark:text-gray-100">Count, clean, convert, and bulk-edit text before publishing or sharing.</p>
        </a>
      </div>
    </section>

    <section class="tb-card mb-8 md:p-8 dark:text-gray-100" aria-labelledby="guides-tools-title">
      <h2 id="guides-tools-title" class="text-xl font-bold mb-4 text-gray-900 dark:text-white">Popular tools behind these guides</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <a href="/tools/json-formatter.html" class="tb-card tb-card-interactive tb-card-soft tb-card-pad-sm">
          <h3 class="font-bold mb-2 text-gray-900 dark:text-white">JSON Formatter</h3>
          <p class="text-sm text-gray-900 dark:text-gray-100">Use the formatter while following the JSON cleanup guide step by step.</p>
        </a>
        <a href="/tools/jwt-decoder.html" class="tb-card tb-card-interactive tb-card-soft tb-card-pad-sm">
          <h3 class="font-bold mb-2 text-gray-900 dark:text-white">JWT Decoder</h3>
          <p class="text-sm text-gray-900 dark:text-gray-100">Inspect token payloads locally before checking verification logic in your app.</p>
        </a>
        <a href="/tools/text-to-slug.html" class="tb-card tb-card-interactive tb-card-soft tb-card-pad-sm">
          <h3 class="font-bold mb-2 text-gray-900 dark:text-white">Text to Slug</h3>
          <p class="text-sm text-gray-900 dark:text-gray-100">Turn headlines into clean URL slugs while following the SEO slug best-practice guide.</p>
        </a>
        <a href="/tools/read-time-calculator.html" class="tb-card tb-card-interactive tb-card-soft tb-card-pad-sm">
          <h3 class="font-bold mb-2 text-gray-900 dark:text-white">Reading Time Calculator</h3>
          <p class="text-sm text-gray-900 dark:text-gray-100">Estimate how long articles take to read before publishing supporting content.</p>
        </a>
        <a href="/tools/word-counter.html" class="tb-card tb-card-interactive tb-card-soft tb-card-pad-sm">
          <h3 class="font-bold mb-2 text-gray-900 dark:text-white">Word Counter</h3>
          <p class="text-sm text-gray-900 dark:text-gray-100">Cross-check article length, excerpt sizes, and meta copy while editing.</p>
        </a>
        <a href="/categories/seo-tools.html" class="tb-card tb-card-soft tb-card-pad-sm">
          <h3 class="font-bold mb-2 text-gray-900 dark:text-white">Browse SEO &amp; Content Tools</h3>
          <p class="text-sm text-gray-900 dark:text-gray-100">See the wider tool set that supports publishing, structured data, and content cleanup.</p>
        </a>
      </div>
    </section>

    <section class="mb-8" aria-labelledby="guides-library-heading">
      <h2 id="guides-library-heading" class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6">Guide articles</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <a href="/guides/json-formatter-guide.html" class="tb-card tb-card-pad-lg">
          <p class="text-sm text-blue-600 dark:text-blue-400 font-bold uppercase tracking-wide mb-2">Developer</p>
          <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-2">Fix Invalid JSON Fast</h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">Understand parser errors, fix the usual syntax mistakes, and choose beautify vs minify correctly.</p>
        </a>
        <a href="/guides/jwt-decoder-guide.html" class="tb-card tb-card-pad-lg">
          <p class="text-sm text-indigo-600 dark:text-indigo-400 font-bold uppercase tracking-wide mb-2">Security</p>
          <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-2">Decode JWT Safely</h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">Learn decode vs verify, which claims to inspect, and safe production practices for auth tokens.</p>
        </a>
        <a href="/guides/seo-slug-best-practices.html" class="tb-card tb-card-pad-lg">
          <p class="text-sm text-sky-700 font-bold uppercase tracking-wide mb-2">SEO</p>
          <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-2">SEO Slug Best Practices</h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">Write shorter, cleaner URLs with better keyword placement and fewer slug mistakes.</p>
        </a>
        <a href="/guides/compress-images-guide.html" class="tb-card tb-card-pad-lg">
          <p class="text-sm text-blue-600 dark:text-blue-400 font-bold uppercase tracking-wide mb-2">Performance</p>
          <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-2">Compress Images for Web</h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">WebP vs JPEG, the quality slider sweet spot, and a checklist before publishing any image.</p>
        </a>
        <a href="/guides/base64-encoding-guide.html" class="tb-card tb-card-pad-lg">
          <p class="text-sm text-blue-600 dark:text-blue-400 font-bold uppercase tracking-wide mb-2">Developer</p>
          <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-2">Base64 Encoding Explained</h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">How encoding works, when to use it (tokens, data URIs, email), and why it is NOT encryption.</p>
        </a>
        <a href="/guides/uuid-guid-guide.html" class="tb-card tb-card-pad-lg">
          <p class="text-sm text-blue-600 dark:text-blue-400 font-bold uppercase tracking-wide mb-2">Developer</p>
          <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-2">UUID and GUID Explained</h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">UUID versions, when to use v4 vs v7, database trade-offs, and GUID vs UUID demystified.</p>
        </a>
        <a href="/guides/url-encoding-guide.html" class="tb-card tb-card-pad-lg">
          <p class="text-sm text-blue-600 dark:text-blue-400 font-bold uppercase tracking-wide mb-2">Developer</p>
          <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-2">URL Encoding Explained</h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">What %20 means, encodeURI vs encodeURIComponent, and how to fix broken links with special characters.</p>
        </a>
        <a href="/guides/qr-code-guide.html" class="tb-card tb-card-pad-lg">
          <p class="text-sm text-blue-600 dark:text-blue-400 font-bold uppercase tracking-wide mb-2">Practical</p>
          <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-2">QR Codes Explained</h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">What to encode, error correction levels, print vs digital best practices, and a deployment checklist.</p>
        </a>
        <a href="/guides/password-guide.html" class="tb-card tb-card-pad-lg">
          <p class="text-sm text-red-600 dark:text-red-400 font-bold uppercase tracking-wide mb-2">Security</p>
          <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-2">Strong Password Guide</h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm">Password entropy, minimum lengths, why reuse is dangerous, and how to store passwords safely.</p>
        </a>
      </div>
    </section>
  </main>`;
---

<BaseLayout title={title} description={description} canonicalPath={canonicalPath} rootPath="/" metadata={metadata} schemas={schemas}>
  <Fragment set:html={mainHtml} />
</BaseLayout>
