---
import GuideLayout from "@/layouts/GuideLayout.astro";
import { SITE_URL } from "@/lib/seo";
import { buildBreadcrumbSchema } from "@/lib/schema";

const title = "JWT Decoder Workflow — Complete Guide | ToolBite";
const description = "Learn JWT decoder safety: inspect headers and payloads, read exp and aud, and never treat decode as signature verification. Practical examples free on ToolBite.";
const canonicalPath = "/guides/jwt-decoder-guide.html";
const pageUrl = `${SITE_URL}${canonicalPath}`;
const schemas = [
  buildBreadcrumbSchema([
    { name: "Home", url: SITE_URL },
    { name: "Guides", url: `${SITE_URL}/guides/index.html` },
    { name: "JWT decoder guide", url: pageUrl }
  ])
];

const mainHtml = String.raw`<div class="guide-page-root w-full py-8">
    <nav class="tb-breadcrumb text-sm text-gray-500 mb-4" aria-label="Breadcrumb">
      <ol class="flex flex-wrap items-center gap-2">
        <li><a href="../" class="hover:text-blue-600 transition">Home</a></li><li>›</li>
        <li><a href="/guides/" class="hover:text-blue-600 transition">Guides</a></li><li>›</li>
        <li class="text-gray-800 dark:text-gray-200 font-medium">JWT Decoder Guide</li>
      </ol>
    </nav>

    <article class="tb-card tb-card-prose tb-card-pad-lg prose max-w-none md:p-8">
      <h1 class="text-3xl md:text-4xl font-extrabold mb-2 text-gray-900 dark:text-white" data-pseo-target="h1">How to decode JWT safely (without trusting payload)</h1>
            <div class="tb-card tb-card-soft tb-card-note tb-card-pad-sm mt-3 mb-8">
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-full bg-blue-100 dark:bg-blue-900/40 text-blue-700 font-bold text-xs flex items-center justify-center">GC</div>
          <p><span class="font-semibold text-gray-900 dark:text-gray-100">Written by <a href="/authors/gabriel-c.html" class="text-blue-600 dark:text-blue-400 hover:underline">Gabriel C.</a></span></p>
        </div>
      </div>
      <p class="text-gray-900 dark:text-gray-100">JWT decoding is useful for debugging auth flows, but decode is not the same as verification. Here is a safe workflow.</p>

      <div class="not-prose mt-6 mb-8 rounded-2xl border border-indigo-100 bg-indigo-50 dark:bg-indigo-900/30 p-4 text-sm text-indigo-900">
        <strong>Important:</strong> this guide is about local inspection and debugging. It does not replace signature verification, issuer checks, or audience validation in your backend.
      </div>

      <h2>1) Decode only for inspection</h2>
      <p>Use a local decoder to inspect the first two segments (<code>header</code> and <code>payload</code>), then verify signature in your backend.</p>

      <h2>2) Check key claims</h2>
      <ul>
        <li><strong>exp</strong>: token expiry time</li>
        <li><strong>iss</strong>: expected issuer</li>
        <li><strong>aud</strong>: intended audience</li>
        <li><strong>sub</strong>: subject/user identifier</li>
      </ul>

      <h2>3) Never authorize from decoded payload alone</h2>
      <p>Decoded data can be forged if signature is not validated. Always run server-side verification before granting access.</p>

      <h2>Common mistakes</h2>
      <ul>
        <li>Treating any decoded token as valid.</li>
        <li>Ignoring clock skew for <code>exp</code>/<code>nbf</code>.</li>
        <li>Not validating issuer/audience.</li>
      </ul>

      <h2>What decode is actually good for</h2>
      <p>Decoding is useful when you need to confirm which claims an identity provider is sending, inspect unexpected payload fields, check whether a token is expired, or compare staging vs production auth behavior without logging the token to a backend tool.</p>

      <h2>A safer team workflow</h2>
      <p>Decode locally in the browser, redact sensitive samples before sharing them in tickets, and keep verification logic in code reviewable backend services. That split keeps debugging fast without turning a convenience tool into part of your trust model.</p>

      <h2>JWT review checklist</h2>
      <ul>
        <li>Confirm the token is meant for the expected environment and app.</li>
        <li>Check whether <code>exp</code>, <code>nbf</code>, and <code>iat</code> line up with your session rules.</li>
        <li>Verify <code>iss</code> and <code>aud</code> server-side before using the token.</li>
        <li>Do not trust custom role or permission claims until signature validation passes.</li>
      </ul>

      <div class="not-prose mt-8 flex flex-wrap gap-3">
        <a href="/tools/jwt-decoder.html" class="tb-btn tb-btn-outline px-5 py-3 rounded-xl">Open JWT Decoder</a>
        <a href="/tools/json-formatter.html" class="tb-btn tb-btn-outline px-5 py-3 rounded-xl">Format decoded JSON</a>
      </div>
    </article>

    <section class="tb-card tb-card-panel tb-card-pad-lg mt-8 md:p-8">
      <h2 class="text-xl font-bold mb-4 text-gray-900 dark:text-white">Continue with related resources</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
        <a href="/categories/developer-tools.html" class="tb-card tb-card-soft tb-card-pad-sm">
          <p class="font-bold text-sm text-gray-900 dark:text-gray-100">Developer Tools</p>
          <p class="text-xs text-gray-500 mt-1">Open related tools for JSON formatting, Base64, hashing, and URL encoding.</p>
        </a>
        <a href="/guides/" class="tb-card tb-card-soft tb-card-pad-sm">
          <p class="font-bold text-sm text-gray-900 dark:text-gray-100">All ToolBite guides</p>
          <p class="text-xs text-gray-500 mt-1">Browse the rest of the guide library for adjacent workflows.</p>
        </a>
        <a href="/tools/json-formatter.html" class="tb-card tb-card-soft tb-card-pad-sm">
          <p class="font-bold text-sm text-gray-900 dark:text-gray-100">JSON Formatter</p>
          <p class="text-xs text-gray-500 mt-1">Clean decoded header or payload JSON after inspection.</p>
        </a>
      </div>
    </section>
    <section class="mt-8 bg-indigo-50 dark:bg-indigo-900/30 rounded-3xl border border-indigo-100 shadow-sm p-6 md:p-8">
      <h2 class="text-xl font-bold mb-4 text-gray-900 dark:text-white">Related authentication tooling</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <a href="/tools/base64-encoder.html" class="tb-card tb-card-interactive">
          <p class="font-bold text-sm text-gray-900 dark:text-gray-100">Base64 Encoder</p>
          <p class="text-xs text-gray-500 mt-1">Useful when you need to inspect or compare encoded values in adjacent auth workflows.</p>
        </a>
        <a href="/categories/developer-tools.html" class="tb-card tb-card-interactive">
          <p class="font-bold text-sm text-gray-900 dark:text-gray-100">Browse Developer Tools</p>
          <p class="text-xs text-gray-500 mt-1">Continue into JSON formatting, hashing, URL encoding, UUID generation, and related debugging utilities.</p>
        </a>
      </div>
    </section>
  <section class="tb-card tb-card-panel tb-card-pad-lg mt-8 not-prose md:p-8" aria-label="Tools used in this guide"><h2 class="text-xl font-bold mb-4 text-gray-900 dark:text-white">Tools used in this guide</h2><div class="flex flex-wrap gap-2"><a href="/tools/jwt-decoder.html" class="tb-btn tb-btn-outline flex items-center gap-2 rounded-xl px-3 py-2"><span aria-hidden="true">🪪</span><span>JWT Decoder</span></a><a href="/tools/json-formatter.html" class="tb-btn tb-btn-outline flex items-center gap-2 rounded-xl px-3 py-2"><span aria-hidden="true">💻</span><span>JSON Formatter</span></a></div></section>
</div>`;
---

<GuideLayout title={title} description={description} canonicalPath={canonicalPath} schemas={schemas}>
  <Fragment set:html={mainHtml} />
</GuideLayout>
