---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { createMetadata } from "@/lib/seo";

const title = "404 Page Not Found — ToolBite Free Online Tools";
const description =
  "This ToolBite page is missing or moved. Search free JSON, text, image, and SEO tools, or return home. Find the right utility in seconds on ToolBite today.";
const canonicalPath = "/404.html";
const metadata = createMetadata({
  title,
  description,
  canonicalPath,
  robots: { index: false, follow: true },
  keywords: ["404", "ToolBite", "page not found", "search tools"]
});
---

<BaseLayout title={title} description={description} canonicalPath={canonicalPath} rootPath="/" metadata={metadata}>
<div class="text-7xl mb-6">🕳️</div>
    <h1 class="text-5xl md:text-6xl font-extrabold text-gray-900 dark:text-gray-100 mb-6" data-pseo-target="h1">404</h1>
    <h2 class="text-2xl md:text-3xl font-bold text-gray-700 dark:text-gray-300 mb-6">Page Not Found</h2>
    <p class="text-lg text-gray-600 dark:text-gray-400 mb-10 leading-relaxed max-w-lg">
      The tool or page you are looking for might have been removed, had its name changed, or is temporarily unavailable.
    </p>
    <div class="w-full max-w-xl mb-6">
      <form action="search.html" method="get" role="search" class="tb-card tb-card-pad-sm flex items-center gap-2">
        <label for="missing-search" class="sr-only">Search ToolBite</label>
        <input id="missing-search" name="q" type="search" placeholder="Try: JSON formatter, QR generator, slug tool..." class="tb-input w-full border outline-none" />
        <button type="submit" class="tb-btn tb-btn-primary">Search</button>
      </form>
    </div>
    <div class="flex flex-wrap justify-center gap-3 mb-8">
      <a href="tools/json-formatter.html" class="tb-btn tb-btn-outline">JSON Formatter</a>
      <a href="tools/password-generator.html" class="tb-btn tb-btn-outline">Password Generator</a>
      <a href="tools/word-counter.html" class="tb-btn tb-btn-outline">Word Counter</a>
      <a href="/guides/" class="tb-btn tb-btn-outline">Browse Guides</a>
    </div>
    <a href="/" class="tb-btn tb-btn-outline inline-block py-3 px-8 rounded-xl">Return to Homepage</a>

</BaseLayout>
