---
import BaseLayout from "@/layouts/BaseLayout.astro";

const title = "Contact | ToolBite";
const description = "Contact ToolBite for bug reports, tool requests, or partnership inquiries. Typical response time is 24–48 hours.";
const canonicalPath = "/contact.html";
---

<BaseLayout title={title} description={description} canonicalPath={canonicalPath} rootPath="/">
<nav class="tb-breadcrumb text-sm text-gray-500 mb-6 text-left" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2">
        <li><a href="/" class="hover:text-blue-600 transition">Home</a></li>
        <li>›</li>
        <li class="text-gray-800 dark:text-gray-200 font-medium">Contact</li>
      </ol>
    </nav>
    <div class="mb-8">
      <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 dark:text-gray-100 mb-4" data-pseo-target="h1">Contact <span class="text-blue-600 dark:text-blue-400">ToolBite</span></h1>
      <p class="text-xl text-gray-600 dark:text-gray-400">Send support questions, bug reports, partnership inquiries, or new tool ideas.</p>
    </div>

    <div id="support" class="tb-card tb-card-tool md:p-12 dark:text-gray-100">
      <p class="text-lg text-gray-700 dark:text-gray-300 mb-6">For support, bug reports, partnerships, or tool requests, email us directly.</p>
      <a href="mailto:support@toolbite.org" class="tb-btn bg-brand-orange border-brand-orange text-white hover:bg-brand-orange-dark tb-btn-lg inline-flex">Email ToolBite Support</a>
    </div>

    <section class="tb-card mt-8 md:p-8 dark:text-gray-100">
      <h2 class="text-2xl font-bold mb-4 text-gray-900 dark:text-white">Popular places to continue</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <a href="/" class="tb-card tb-card-soft tb-card-pad-sm">
          <h3 class="font-bold mb-2 text-gray-900 dark:text-white">Homepage</h3>
          <p class="text-sm text-gray-900 dark:text-gray-100">Start from the main hub to browse popular tools and categories.</p>
        </a>
        <a href="/guides/" class="tb-card tb-card-soft tb-card-pad-sm">
          <h3 class="font-bold mb-2 text-gray-900 dark:text-white">Guides</h3>
          <p class="text-sm text-gray-900 dark:text-gray-100">Read practical tutorials before sending a support question or feature request.</p>
        </a>
        <a href="categories/developer-tools.html" class="tb-card tb-card-soft tb-card-pad-sm">
          <h3 class="font-bold mb-2 text-gray-900 dark:text-white">Developer Tools</h3>
          <p class="text-sm text-gray-900 dark:text-gray-100">Go directly to JSON, JWT, Base64, hashing, and encoding utilities.</p>
        </a>
      </div>
    </section>

  <Fragment slot="head">
<title>Contact | ToolBite</title>
  <style id="critical-css">body{font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;-webkit-font-smoothing:antialiased;margin:0;background-color:#f9fafb}.tb-hero{position:relative;overflow:hidden;background:linear-gradient(125deg,#014f55 0%,#01696f 42%,#0f766e 100%);color:#fff;padding:3rem 1rem}.tb-hero::before,.tb-hero::after{content:'';position:absolute;border-radius:50%;filter:blur(64px);opacity:.45;pointer-events:none}.tb-hero::before{width:min(80vw,28rem);height:min(80vw,28rem);background:#2dd4bf;top:-15%;right:-5%}.tb-hero::after{width:min(70vw,22rem);height:min(70vw,22rem);background:#34d399;bottom:-20%;left:-8%}.tb-hero-inner{position:relative;z-index:1;max-width:56rem;margin:0 auto}.tb-hero h1{font-family:'Plus Jakarta Sans','Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-weight:800;font-size:2.25rem;line-height:2.5rem;margin-bottom:1rem;color:#fff}@media (min-width:768px){.tb-hero{padding:5rem 1rem}.tb-hero h1{font-size:3.75rem;line-height:1}}.tb-hero p{font-size:1.125rem;line-height:1.75rem;color:rgba(255,255,255,0.9);font-weight:500;margin-bottom:2rem}@media (min-width:768px){.tb-hero p{font-size:1.5rem;line-height:2rem}}#site-header{background:#fff;box-shadow:0 1px 3px rgba(0,0,0,.1);position:sticky;top:0;z-index:50}img.header-logo{height:2.5rem!important;width:auto!important;aspect-ratio:384/105;display:block}.skip-link{position:absolute;transform:translateY(-200%)}h1,h2{font-family:'Plus Jakarta Sans','Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-weight:800}.tb-breadcrumb ol{list-style:none;margin:0;padding:0}</style>
<link rel="icon" type="image/svg+xml" href="/assets/images/favicon.svg">
  <link rel="manifest" href="manifest.json">
  <link rel="canonical" href="https://toolbite.org/contact.html">
<link rel="alternate" hreflang="x-default" href="https://toolbite.org/contact.html">
  <link rel="alternate" hreflang="en" href="https://toolbite.org/contact.html">
  <meta name="description" content="Contact ToolBite for bug reports, tool requests, or partnership inquiries. Typical response time is 24–48 hours.">
  <meta name="theme-color" content="#2563eb">
  <meta name="author" content="ToolBite">
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1">
  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="ToolBite">
  <meta property="og:url" content="https://toolbite.org/contact.html">
  <meta property="og:title" content="Contact | ToolBite">
  <meta property="og:description" content="Use Contact | ToolBite on ToolBite for fast, privacy-first browser workflows with practical steps, clear results, and reliable outputs for everyday tasks.">
  <meta property="og:image" content="https://toolbite.org/assets/images/social-preview.jpg">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="Contact ToolBite — Bugs, ideas &amp; partnerships — ToolBite">
  <meta property="og:locale" content="en_US">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@toolbite">
  <meta name="twitter:creator" content="@toolbite">
  <meta name="twitter:title" content="Contact ToolBite — Bugs, ideas &amp; partnerships">
  <meta name="twitter:description" content="Use Contact | ToolBite on ToolBite for fast, privacy-first browser workflows with practical steps, clear results, and reliable outputs for everyday tasks.">
  <meta name="twitter:image" content="https://toolbite.org/assets/images/social-preview.jpg">
  <meta name="twitter:image:alt" content="Contact ToolBite — Bugs, ideas &amp; partnerships — ToolBite">
<!-- GA4: async so it never blocks the parser -->
<meta name="google-adsense-account" content="ca-pub-5233222002046639">
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5233222002046639" crossorigin="anonymous"></script>
  <noscript><link rel="stylesheet" href="assets/css/tailwind.min.css"></noscript>
  
  <noscript><link rel="stylesheet" href="assets/css/global.min.css"></noscript>
  </Fragment>
</BaseLayout>
