---
import BaseLayout from "@/layouts/BaseLayout.astro";

const title = "Terms of Service | ToolBite";
const description = "Use Terms of Service | ToolBite on ToolBite for fast, privacy-first browser workflows with practical steps, clear results, and reliable outputs for everyday tas";
const canonicalPath = "/terms.html";
---

<BaseLayout title={title} description={description} canonicalPath={canonicalPath} rootPath="/">
<nav class="tb-breadcrumb text-sm text-gray-500 mb-6" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2">
        <li><a href="/" class="hover:text-blue-600 transition">Home</a></li>
        <li>›</li>
        <li class="text-gray-800 dark:text-gray-200 font-medium">Terms of Service</li>
      </ol>
    </nav>
    <div class="text-center mb-8">
      <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 dark:text-gray-100 mb-4" data-pseo-target="h1">ToolBite <span class="text-blue-600 dark:text-blue-400">Terms of Service</span></h1>
      <p class="text-lg text-gray-500">Last updated: May 8, 2026</p>
    </div>

    <div class="tb-card tb-card-tool md:p-12 leading-relaxed text-gray-700 dark:text-gray-300">

      <h2 class="text-2xl font-bold mb-3 text-gray-900 dark:text-white">1. Agreement</h2>
      <p class="mb-8">By accessing or using ToolBite.org ("ToolBite", "we", "us"), you agree to these Terms of Service. If you do not agree, please do not use the site.</p>

      <h2 class="text-2xl font-bold mb-3 text-gray-900 dark:text-white">2. Description of Service</h2>
      <p class="mb-8">ToolBite provides free, browser-based utilities for personal and professional use. Features and tools may change at any time without notice.</p>

      <h2 class="text-2xl font-bold mb-3 text-gray-900 dark:text-white">3. Acceptable Use</h2>
      <p class="mb-4">You agree not to misuse the service. For example, you must not:</p>
      <ul class="list-disc pl-6 space-y-2 mb-8">
        <li>Attempt to disrupt, overload, or compromise the site or its infrastructure.</li>
        <li>Use the tools to violate applicable laws or third-party rights.</li>
        <li>Scrape or automate access in a way that degrades service for others.</li>
      </ul>

      <h2 class="text-2xl font-bold mb-3 text-gray-900 dark:text-white">4. No Warranty</h2>
      <p class="mb-8">The site and all tools are provided "as is" without warranties of any kind. We do not guarantee uninterrupted access, error-free results, or fitness for a particular purpose. You use ToolBite at your own risk.</p>

      <h2 class="text-2xl font-bold mb-3 text-gray-900 dark:text-white">5. Limitation of Liability</h2>
      <p class="mb-8">To the fullest extent permitted by law, ToolBite and its operators shall not be liable for any indirect, incidental, special, or consequential damages arising from your use of the site or reliance on any output from our tools.</p>

      <h2 class="text-2xl font-bold mb-3 text-gray-900 dark:text-white">6. Third-Party Services</h2>
      <p class="mb-8">The site may include links, advertisements, or embedded content from third parties (for example, advertising networks). Those services are governed by their own terms and policies.</p>

      <h2 class="text-2xl font-bold mb-3 text-gray-900 dark:text-white">7. Changes</h2>
      <p class="mb-8">We may update these terms from time to time. Continued use of ToolBite after changes constitutes acceptance of the revised terms.</p>

      <h2 class="text-2xl font-bold mb-3 text-gray-900 dark:text-white">8. Contact</h2>
      <p>For questions about these terms, please use our <a href="/contact.html" class="text-blue-600 dark:text-blue-400 hover:underline">contact page</a>.</p>
    </div>

    <section class="tb-card mt-8 md:p-8 dark:text-gray-100">
      <h2 class="text-2xl font-bold mb-4 text-gray-900 dark:text-white">Explore related pages</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <a href="/privacy.html" class="tb-card tb-card-soft tb-card-pad-sm">
          <h3 class="font-bold mb-2 text-gray-900 dark:text-white">Privacy Policy</h3>
          <p class="text-sm text-gray-900 dark:text-gray-100">See how ToolBite handles local processing, ads, cookies, and third-party services.</p>
        </a>
        <a href="/about.html" class="tb-card tb-card-soft tb-card-pad-sm">
          <h3 class="font-bold mb-2 text-gray-900 dark:text-white">About ToolBite</h3>
          <p class="text-sm text-gray-900 dark:text-gray-100">Read the product positioning and privacy-first mission behind the tools.</p>
        </a>
        <a href="/categories/text-tools.html" class="tb-card tb-card-soft tb-card-pad-sm">
          <h3 class="font-bold mb-2 text-gray-900 dark:text-white">Text Tools</h3>
          <p class="text-sm text-gray-900 dark:text-gray-100">Browse one of the main tool hubs linked from across the site.</p>
        </a>
      </div>
    </section>

  <Fragment slot="head">
<title>Terms of Service | ToolBite</title>
  <meta name="description" content="Use Terms of Service | ToolBite on ToolBite for fast, privacy-first browser workflows with practical steps, clear results, and reliable outputs for everyday tas">
  <link rel="canonical" href="https://toolbite.org/terms.html">
  <link rel="alternate" hreflang="x-default" href="https://toolbite.org/terms.html">
  <link rel="alternate" hreflang="en" href="https://toolbite.org/terms.html">
  <meta name="theme-color" content="#0a0d12">
  <meta name="author" content="ToolBite">
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="ToolBite">
  <meta property="og:url" content="https://toolbite.org/terms.html">
  <meta property="og:title" content="Terms of Service | ToolBite">
  <meta property="og:description" content="Use Terms of Service | ToolBite on ToolBite for fast, privacy-first browser workflows with practical steps, clear results, and reliable outputs for everyday tas">
  <meta property="og:image" content="https://toolbite.org/assets/images/social-preview.jpg">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:locale" content="en_US">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@toolbite">
  <meta name="twitter:creator" content="@toolbite">
  <meta name="twitter:title" content="Terms of Service | ToolBite">
  <meta name="twitter:description" content="Use Terms of Service | ToolBite on ToolBite for fast, privacy-first browser workflows with practical steps, clear results, and reliable outputs for everyday tas">
  <meta name="twitter:image" content="https://toolbite.org/assets/images/social-preview.jpg">
  </Fragment>
</BaseLayout>
