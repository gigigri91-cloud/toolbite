---
import CategoryPage from "@/components/discovery/CategoryPage.astro";
import CategoryLayout from "@/layouts/CategoryLayout.astro";
import { createCategoryMetadata } from "@/lib/seo";

const title = "Developer Tools Online — Free JSON, UUID, Hash & More | ToolBite";
const description =
  "8 free developer tools including JSON formatter, UUID generator, JWT decoder, and Base64 encoder. All run in your browser — no account needed. Try ToolBite.";
const canonicalPath = "/categories/developer-tools.html";

const metadata = createCategoryMetadata({
  title,
  description,
  canonicalPath,
  keywords: ["developer tools", "json formatter", "jwt decoder", "uuid", "hash"]
});

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Developer Tools Online — Free JSON, UUID, Hash & More | ToolBite",
    url: "https://toolbite.org/categories/developer-tools.html",
    description:
      "Eight free developer utilities—JSON formatter, JWT decoder, Base64, UUID, hashing, and more—run locally in your browser without uploading payloads.",
    dateModified: "2026-05-08"
  }
];
---

<CategoryLayout title={title} description={description} canonicalPath={canonicalPath} metadata={metadata} schemas={schemas}>
  <CategoryPage
    slug="developer-tools"
    title="Developer & debugging tools"
    heroDescription="Decode, validate, and transform payloads faster with privacy-first utility tools designed for daily engineering workflows."
  />
</CategoryLayout>
