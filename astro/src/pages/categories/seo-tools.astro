---
import CategoryPage from "@/components/discovery/CategoryPage.astro";
import CategoryLayout from "@/layouts/CategoryLayout.astro";
import { createCategoryMetadata } from "@/lib/seo";

const title = "SEO Tools Online — Free Slug Generator, URL Encoder & More | ToolBite";
const description =
  "Free SEO tools including text to slug converter, URL encoder, and reading time calculator. Improve URLs and metadata faster with ToolBite free tools now.";
const canonicalPath = "/categories/seo-tools.html";

const metadata = createCategoryMetadata({
  title,
  description,
  canonicalPath,
  keywords: ["seo tools", "slug generator", "read time", "publishing tools"]
});

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "SEO Tools Online — Free Slug Generator, URL Encoder & More | ToolBite",
    url: "https://toolbite.org/categories/seo-tools.html",
    description:
      "Free slug, URL encoding, and reading-time utilities help you prep publishing tasks locally without uploading your draft copy to ToolBite servers.",
    dateModified: "2026-05-08"
  }
];
---

<CategoryLayout title={title} description={description} canonicalPath={canonicalPath} metadata={metadata} schemas={schemas}>
  <CategoryPage
    slug="seo-tools"
    title="SEO & content tools"
    heroDescription="Prepare content for publication with precision, from slug hygiene and metadata readiness to readability and structure checks."
  />
</CategoryLayout>
