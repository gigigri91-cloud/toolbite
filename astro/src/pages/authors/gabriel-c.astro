---
import BaseLayout from "@/layouts/BaseLayout.astro";

const title = "Gabriel C. — Author | ToolBite";
const description = "Use Gabriel C. — Author | ToolBite on ToolBite for fast, privacy-first browser workflows with practical steps, clear results, and reliable outputs for everyday";
const canonicalPath = "/authors/gabriel-c.html";
const mainHtml = String.raw`<main class="flex-grow max-w-5xl mx-auto px-4 py-12 w-full">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-3">Gabriel C.</h1>
    <p class="text-sm font-semibold text-blue-700 mb-4">Developer &amp; Technical Writer</p>
    <p class="text-gray-700 mb-6">Gabriel C. is an indie developer based in Bucharest, Romania, and built ToolBite as a free resource for developers and content creators.</p>

    <section class="tb-card md:p-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-5">Guides by Gabriel C.</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3" id="author-guides-list"></div>
    </section>
  </main>`;
const headHtml = String.raw`<title>Gabriel C. — Author | ToolBite</title>
  <meta name="description" content="Use Gabriel C. — Author | ToolBite on ToolBite for fast, privacy-first browser workflows with practical steps, clear results, and reliable outputs for everyday">
  <link rel="canonical" href="https://toolbite.org/authors/gabriel-c.html">
  <link rel="alternate" hreflang="x-default" href="https://toolbite.org/authors/gabriel-c.html">
  <link rel="alternate" hreflang="en" href="https://toolbite.org/authors/gabriel-c.html">
  <meta name="theme-color" content="#0a0d12">
  <meta name="author" content="Gabriel C.">
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="ToolBite">
  <meta property="og:url" content="https://toolbite.org/authors/gabriel-c.html">
  <meta property="og:title" content="Gabriel C. — Author | ToolBite">
  <meta property="og:description" content="Use Gabriel C. — Author | ToolBite on ToolBite for fast, privacy-first browser workflows with practical steps, clear results, and reliable outputs for everyday">
  <meta property="og:image" content="https://toolbite.org/assets/images/social-preview.jpg">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:locale" content="en_US">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@toolbite">
  <meta name="twitter:creator" content="@toolbite">
  <meta name="twitter:title" content="Gabriel C. — Author | ToolBite">
  <meta name="twitter:description" content="Use Gabriel C. — Author | ToolBite on ToolBite for fast, privacy-first browser workflows with practical steps, clear results, and reliable outputs for everyday">
  <meta name="twitter:image" content="https://toolbite.org/assets/images/social-preview.jpg">`;
---

<BaseLayout title={title} description={description} canonicalPath={canonicalPath} rootPath="/">
  <Fragment set:html={mainHtml} />
  <Fragment slot="head" set:html={headHtml} />
</BaseLayout>
