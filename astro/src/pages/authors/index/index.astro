---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE_URL, createMetadata } from "@/lib/seo";
import { buildBreadcrumbSchema } from "@/lib/schema";

const title = "ToolBite Authors — Guides & Technical Writers | ToolBite";
const description =
  "Discover who writes ToolBite guides and tool pages: editorial standards, expertise, and how to follow authors behind tutorials. Read more on ToolBite today.";
const canonicalPath = "/authors/index.html";
const metadata = createMetadata({
  title,
  description,
  canonicalPath,
  keywords: ["ToolBite authors", "technical writers", "guide authors", "ToolBite team", "Gabriel C."]
});
const pageUrl = `${SITE_URL}${canonicalPath}`;
const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "ToolBite authors",
    url: pageUrl,
    description: "Meet the authors behind ToolBite guides and tools."
  },
  buildBreadcrumbSchema([
    { name: "Home", url: SITE_URL },
    { name: "Authors", url: pageUrl }
  ])
];
const mainHtml = String.raw`<main class="flex-grow max-w-5xl mx-auto px-4 py-12 w-full">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-6">Authors</h1>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <a href="../gabriel-c.html" class="tb-card tb-card-interactive transition block">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-14 h-14 rounded-full bg-blue-100 text-blue-700 font-bold text-xl flex items-center justify-center">GC</div>
          <div>
            <h2 class="text-xl font-bold text-gray-900">Gabriel C.</h2>
            <p class="text-sm text-blue-700 font-semibold">Developer &amp; Technical Writer</p>
          </div>
        </div>
        <p class="text-gray-600 text-sm">Indie developer in Bucharest, Romania. Builds ToolBite as a free, practical resource for developers and content creators.</p>
      </a>
    </div>
  </main>`;
---

<BaseLayout title={title} description={description} canonicalPath={canonicalPath} rootPath="/" metadata={metadata} schemas={schemas}>
  <Fragment set:html={mainHtml} />
</BaseLayout>
