---
import CategoryHighlights from "@/components/discovery/CategoryHighlights.astro";
import PopularToolsSection from "@/components/discovery/PopularToolsSection.astro";
import RecentlyAddedSection from "@/components/discovery/RecentlyAddedSection.astro";
import RecommendedToolsSection from "@/components/discovery/RecommendedToolsSection.astro";
import TrendingToolsSection from "@/components/discovery/TrendingToolsSection.astro";
import ToolCard from "@/components/discovery/ToolCard.astro";
import SearchInput from "@/components/search/SearchInput.astro";
import SearchOverlay from "@/components/search/SearchOverlay.astro";
import SearchSuggestions from "@/components/search/SearchSuggestions.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { HOMEPAGE_TITLE, createMetadata } from "@/lib/seo";
import { buildOrganizationSchema, buildWebSiteSchema } from "@/lib/schema";
import { getAllTools, getCategoryTools, getPopularTools } from "@/lib/tools";

const title = HOMEPAGE_TITLE;
const description = "Discover privacy-first AI productivity workflows for writing, development, SEO, and media optimization. Fast browser-native tools with startup-grade UX.";
const canonicalPath = "/";
const metadata = createMetadata({
  title,
  description,
  canonicalPath,
  keywords: ["ai productivity", "browser tools", "developer workflows", "seo workflows", "toolbite ecosystem"]
});

const schemas = [buildWebSiteSchema(), buildOrganizationSchema()];
const popularGridTools = getPopularTools(12);
const toolsTotal = getAllTools().length;
const aiTools = getPopularTools(6).filter((tool) =>
  tool.keywords.some((k) => ["json", "slug", "read", "jwt", "text", "image"].includes(k.toLowerCase()))
);
const trustStats = [
  { label: "Browser-native workflows", value: "100%" },
  { label: "Categories powering discovery", value: "4+" },
  { label: "Tools and guides connected", value: "30+" },
  { label: "Server upload required", value: "0" }
];
const categoryFeatured = getCategoryTools("developer-tools").slice(0, 4);
---

<BaseLayout title={title} description={description} canonicalPath={canonicalPath} metadata={metadata} schemas={schemas}>
  <section class="home-hero">
    <div class="hero-glow-blue" aria-hidden="true"></div>
    <div class="hero-glow-orange" aria-hidden="true"></div>
    <div class="hero-content">
      <div class="terminal-tag">▶ 20 free tools — no login required</div>
      <h1>Build faster workflows without leaving your browser.</h1>
      <p class="hero-copy">
        ToolBite turns isolated utilities into a connected discovery layer for writing, development, SEO, and media operations.
        Explore, chain, and reuse workflows in seconds.
      </p>
      <div class="hero-actions">
        <a href="/search.html" class="tb-btn tb-btn-primary cta-terminal"><span class="cta-dollar">$</span><span>explore_tools()</span></a>
        <a href="/categories/developer-tools.html" class="tb-btn tb-btn-secondary">Open workflow categories</a>
      </div>
      <div class="hero-search">
        <SearchInput id="search-input" placeholder="Search workflows, tools, or guides..." hotkeyLabel="Ctrl/⌘K" />
      </div>
      <SearchSuggestions />
    </div>
  </section>

  <div class="stats-bar tb-reveal">
    <div class="stat">
      <span class="stat-num blue">20</span><span class="stat-label">free tools</span>
    </div>
    <div class="stat">
      <span class="stat-num orange">100%</span><span class="stat-label">client-side</span>
    </div>
    <div class="stat">
      <span class="stat-num purple">0</span><span class="stat-label">login needed</span>
    </div>
    <div class="stat">
      <span class="stat-num teal">∞</span><span class="stat-label">free forever</span>
    </div>
  </div>

  <section class="home-section tb-reveal home-popular-tools">
    <p class="home-popular-kicker">
      <span class="home-popular-kicker__accent">// popular tools</span>
      <span class="home-popular-kicker__meta"> [ {toolsTotal} total ]</span>
    </p>
    <div class="tools-grid">
      {popularGridTools.map((tool) => (
        <ToolCard tool={tool} />
      ))}
    </div>
  </section>

  <section class="home-section tb-reveal">
    <div class="section-head">
      <h2>Smart search command center</h2>
      <p>Instant discovery with keyboard-first navigation and contextual suggestions.</p>
    </div>
    <div class="search-command-card tb-card tb-card-panel tb-card-pad-lg">
      <div class="command-grid">
        <div>
          <p class="command-title">Quick-open style navigation</p>
          <p class="command-copy">Press <kbd>Ctrl/⌘K</kbd> or <kbd>/</kbd> to jump into command-style search from anywhere.</p>
        </div>
        <a href="/search.html" class="tb-btn tb-btn-secondary">Open full search</a>
      </div>
    </div>
  </section>

  <section class="home-section tb-reveal">
    <TrendingToolsSection />
  </section>

  <section class="home-section tb-reveal">
    <div class="section-head">
      <h2>AI tools for modern workflows</h2>
      <p>Prompt-ready utilities for structured output, content transformation, and optimization loops.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {aiTools.map((tool) => (
        <a href={`/${tool.url}`} class="tb-card tb-card-interactive tb-card-pad-lg ai-card">
          <p class="ai-label">AI workflow</p>
          <h3 class="font-bold text-lg">{tool.icon || "🧠"} {tool.title}</h3>
          <p class="text-sm">{tool.description}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="home-section tb-reveal">
    <CategoryHighlights
      categorySlug="developer-tools"
      categoryTitle="Popular categories"
      heroDescription="Explore curated category hubs with built-in cross-linking and workflow context."
      featuredTools={categoryFeatured}
    />
  </section>

  <section class="home-section tb-reveal">
    <RecentlyAddedSection />
  </section>

  <section class="home-section tb-reveal">
    <div class="section-head">
      <h2>Why teams adopt ToolBite</h2>
      <p>Engineered for speed, privacy, and operational clarity across daily tasks.</p>
    </div>
    <div class="benefits-grid">
      <article class="tb-card tb-card-panel tb-card-pad-lg"><h3>Browser-native privacy</h3><p>Core workflows run locally, reducing upload friction and risk.</p></article>
      <article class="tb-card tb-card-panel tb-card-pad-lg"><h3>Search-first exploration</h3><p>Command-style discovery helps users move from intent to action quickly.</p></article>
      <article class="tb-card tb-card-panel tb-card-pad-lg"><h3>Connected ecosystem</h3><p>Contextual linking turns isolated tasks into repeatable multi-step workflows.</p></article>
    </div>
  </section>

  <section class="home-section tb-reveal">
    <div class="section-head">
      <h2>Trust by architecture</h2>
      <p>Platform fundamentals designed for reliability and scale.</p>
    </div>
    <div class="stats-grid">
      {trustStats.map((item) => (
        <article class="tb-card tb-card-panel tb-card-pad-lg stat-card">
          <p class="stat-value">{item.value}</p>
          <p class="stat-label">{item.label}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="home-section tb-reveal">
    <RecommendedToolsSection />
  </section>

  <section class="home-section tb-reveal">
    <div class="discovery-cta tb-card tb-card-panel tb-card-pad-lg">
      <h2>Discover your next productivity stack</h2>
      <p>Move from one-off utility usage to a high-velocity workflow ecosystem.</p>
      <div class="hero-actions">
        <a href="/search.html" class="tb-btn tb-btn-primary">Launch command search</a>
        <a href="/categories/text-tools.html" class="tb-btn tb-btn-secondary">Browse all categories</a>
      </div>
    </div>
  </section>

  <section class="home-section tb-reveal">
    <div class="premium-footer tb-card tb-card-panel tb-card-pad-lg">
      <p class="hero-kicker">ToolBite ecosystem</p>
      <h2>Built for modern operators, creators, and product teams.</h2>
      <p>Ultra-fast static-first architecture with scalable discovery and SEO-safe growth for hundreds of tools.</p>
      <div class="premium-links">
        <a href="/guides/">Guides</a>
        <a href="/about.html">About</a>
        <a href="/contact.html">Contact</a>
        <a href="/privacy.html">Privacy</a>
      </div>
    </div>
  </section>

  <SearchOverlay>
    <SearchInput id="search-overlay-input" placeholder="Quick open tools and guides..." />
    <SearchSuggestions />
    <p class="text-sm mt-3">Press <kbd>Esc</kbd> to close command search.</p>
  </SearchOverlay>

  <Fragment slot="scripts">
    <script defer src="/assets/js/search.js"></script>
  </Fragment>
</BaseLayout>

<style>
  .home-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.25rem;
    margin-bottom: 1.5rem;
  }
  .home-hero {
    position: relative;
    overflow: hidden;
    max-width: 1200px;
    margin: 1rem auto 1.25rem;
    padding: 0 1.25rem;
    border-radius: 12px;
    border: 1px solid var(--border-subtle, var(--color-border-primary));
    background: var(--bg-secondary, var(--color-bg-secondary));
  }
  .hero-content {
    position: relative;
    z-index: 1;
    padding: clamp(1.25rem, 3vw, 2.5rem) 0;
  }
  .hero-glow-blue {
    position: absolute;
    top: -80px;
    left: -100px;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(26, 95, 217, 0.15) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }
  .hero-glow-orange {
    position: absolute;
    top: -60px;
    right: -80px;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(245, 166, 35, 0.1) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }
  .stats-bar {
    max-width: 1200px;
    margin: 0 auto 1.5rem;
    padding: 0.85rem 1.25rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-around;
    align-items: center;
    gap: 0.75rem 1rem;
    border-top: 1px solid var(--border-subtle, var(--color-border-primary));
    border-bottom: 1px solid var(--border-subtle, var(--color-border-primary));
    background: transparent;
  }
  .stats-bar .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.25rem;
    min-width: 5.5rem;
  }
  .stats-bar .stat-num {
    font-size: 24px;
    font-weight: 900;
    font-family: var(--font-mono);
    line-height: 1.1;
  }
  .stats-bar .stat-num.blue {
    color: #4d9fff;
  }
  .stats-bar .stat-num.orange {
    color: #f5a623;
  }
  .stats-bar .stat-num.purple {
    color: #a855f7;
  }
  .stats-bar .stat-num.teal {
    color: #2dd4bf;
  }
  .stats-bar .stat-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted, var(--color-text-muted));
    font-weight: 600;
  }
  .home-popular-kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    margin: 0 0 0.65rem;
    letter-spacing: 0.06em;
  }
  .home-popular-kicker__accent {
    color: #f5a623;
  }
  .home-popular-kicker__meta {
    color: #1e3a5a;
  }
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }
  @media (max-width: 960px) {
    .tools-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 520px) {
    .tools-grid {
      grid-template-columns: 1fr;
    }
  }
  .hero-kicker {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }
  .terminal-tag {
    font-family: var(--font-mono);
    color: var(--color-brand-blue);
    background: #0d1e35;
    border: 1px solid var(--color-border-accent-blue);
    padding: 5px 12px;
    border-radius: 4px;
    display: inline-flex;
    margin-bottom: 0.8rem;
  }
  .home-hero h1 {
    margin: 0;
    font-size: clamp(2rem, 4.4vw, 3.8rem);
    line-height: 1.05;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
  }
  .hero-copy {
    margin-top: 0.9rem;
    max-width: 60ch;
    font-size: clamp(1rem, 1.8vw, 1.12rem);
    color: var(--color-text-secondary);
  }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 0.7rem; margin-top: 1rem; }
  .cta-terminal { font-family: var(--font-mono); }
  .cta-dollar { color: var(--color-brand-orange); }
  .section-head h2 {
    margin: 0;
    font-size: clamp(1.3rem, 3vw, 2rem);
    color: var(--color-text-primary);
    letter-spacing: -0.01em;
  }
  .section-head p { margin: 0.35rem 0 0.85rem; color: var(--color-text-secondary); }
  .ai-card { transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease; }
  .ai-card:hover { transform: translateY(-3px); border-color: var(--color-border-accent-blue); box-shadow: 0 12px 26px color-mix(in srgb, var(--color-brand-blue) 22%, transparent); }
  .ai-card h3 { color: var(--color-text-primary); }
  .ai-card p { color: var(--color-text-secondary); }
  .ai-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-brand-blue); margin-bottom: 0.4rem; }
  .benefits-grid,
  .stats-grid { display: grid; gap: 0.85rem; grid-template-columns: repeat(1, minmax(0, 1fr)); }
  @media (min-width: 768px) {
    .benefits-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .stats-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); }
  }
  .benefits-grid h3 { margin: 0 0 0.45rem; font-size: 1.02rem; color: var(--color-text-primary); }
  .benefits-grid p { margin: 0; color: var(--color-text-secondary); font-size: 0.95rem; }
  .stat-value { margin: 0; font-size: 1.7rem; font-weight: 800; color: var(--color-brand-blue); }
  .stat-card .stat-label { margin: 0.25rem 0 0; color: var(--color-text-muted); font-size: 0.88rem; }
  .discovery-cta,
  .premium-footer {
    background:
      radial-gradient(100% 120% at 90% -20%, color-mix(in srgb, var(--color-brand-blue) 18%, transparent), transparent 62%),
      var(--color-bg-card);
  }
  .discovery-cta h2,
  .premium-footer h2 { margin: 0 0 0.35rem; color: var(--color-text-primary); }
  .discovery-cta p,
  .premium-footer p { margin: 0; color: var(--color-text-secondary); }
  .premium-links { margin-top: 0.85rem; display: flex; flex-wrap: wrap; gap: 0.75rem; }
  .premium-links a { color: var(--color-text-secondary); text-decoration: none; border-bottom: 1px solid transparent; }
  .premium-links a:hover { border-bottom-color: var(--color-brand-blue); color: var(--color-brand-blue); }
  .search-command-card .command-grid { display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: space-between; align-items: center; }
  .command-title { margin: 0 0 0.25rem; font-weight: 700; color: var(--color-text-primary); }
  .command-copy { margin: 0; color: var(--color-text-secondary); }
  .search-command-card kbd { color: var(--color-brand-orange); background: #0d1e35; border: 1px solid var(--color-border-accent-orange); border-radius: 4px; padding: 0.05rem 0.35rem; font-family: var(--font-mono); }
  @media (prefers-reduced-motion: reduce) {
    .ai-card { transition: none; }
    .ai-card:hover { transform: none; }
  }
</style>
