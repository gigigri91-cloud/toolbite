---
import ToolInterfaceWrapper from "@/components/tools/ToolInterfaceWrapper.astro";
import { getToolPageContent } from "@/data/tool-pages";
import ToolPageLayout from "@/layouts/ToolPageLayout.astro";

const content = getToolPageContent("image-compressor");
---

<ToolPageLayout slug="image-compressor" content={content} toolScript="/assets/js/tools/image-compressor.js">
  <ToolInterfaceWrapper
    title="Compress image files"
    privacyNote="Compression uses local canvas processing in your browser."
  >
    <div class="grid md:grid-cols-2 gap-3 mb-4">
      <div>
        <label for="file-in" class="block mb-2 text-sm text-gray-700 dark:text-gray-300">Upload image</label>
        <input id="file-in" type="file" accept="image/*" class="tb-input" />
      </div>
      <div>
        <label for="mime-out" class="block mb-2 text-sm text-gray-700 dark:text-gray-300">Output format</label>
        <select id="mime-out" class="tb-select">
          <option value="image/jpeg">JPEG</option>
          <option value="image/webp">WebP</option>
        </select>
      </div>
    </div>
    <div class="mb-4">
      <label for="quality" class="block mb-2 text-sm text-gray-700 dark:text-gray-300">Quality: <span id="q-val">0.8</span></label>
      <input id="quality" type="range" class="w-full" min="0.1" max="1" step="0.1" value="0.8" />
    </div>
    <div class="flex flex-wrap gap-2 mb-4">
      <button id="compress-btn" class="tb-btn tb-btn-primary" disabled>Compress</button>
      <a id="dl" href="#" class="tb-btn tb-btn-outline hidden">Download compressed file</a>
    </div>
    <p id="hint" class="hidden text-sm text-amber-700 dark:text-amber-400 mb-3">PNG transparency can flatten on JPEG output.</p>
    <p id="stats" class="text-sm text-gray-600 dark:text-gray-400"></p>
    <canvas id="cv" class="hidden"></canvas>
  </ToolInterfaceWrapper>
</ToolPageLayout>
