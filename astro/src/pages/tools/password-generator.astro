---
import ToolInterfaceWrapper from "@/components/tools/ToolInterfaceWrapper.astro";
import { getToolPageContent } from "@/data/tool-pages";
import ToolPageLayout from "@/layouts/ToolPageLayout.astro";

const content = getToolPageContent("password-generator");
---

<ToolPageLayout slug="password-generator" content={content} toolScript="/assets/js/tools/password-generator.js">
  <ToolInterfaceWrapper title="Generate secure passwords" privacyNote="Passwords are generated on your device.">
    <label for="pwdLength" class="block mb-2 text-sm text-gray-700 dark:text-gray-300">Length</label>
    <input id="pwdLength" type="number" min="4" max="128" value="16" class="tb-input mb-4" />
    <div class="grid sm:grid-cols-2 gap-2 mb-4 text-sm text-gray-700 dark:text-gray-300">
      <label><input id="incUppercase" type="checkbox" checked class="mr-1" /> Uppercase</label>
      <label><input id="incLowercase" type="checkbox" checked class="mr-1" /> Lowercase</label>
      <label><input id="incNumbers" type="checkbox" checked class="mr-1" /> Numbers</label>
      <label><input id="incSymbols" type="checkbox" checked class="mr-1" /> Symbols</label>
    </div>
    <div class="flex flex-wrap gap-2 mb-4">
      <button onclick="generatePassword()" class="tb-btn tb-btn-primary">Generate</button>
      <button onclick="copyPassword()" id="copyBtn" class="tb-btn tb-btn-neutral">Copy</button>
    </div>
    <textarea id="passwordResult" readonly class="tb-textarea tb-textarea-mono w-full h-24"></textarea>
  </ToolInterfaceWrapper>
</ToolPageLayout>
