---
import ToolInterfaceWrapper from "@/components/tools/ToolInterfaceWrapper.astro";
import { getToolPageContent } from "@/data/tool-pages";
import ToolPageLayout from "@/layouts/ToolPageLayout.astro";

const content = getToolPageContent("json-formatter");
---

<ToolPageLayout slug="json-formatter" content={content} toolScript="/assets/js/tools/json-formatter.js">
  <ToolInterfaceWrapper
    title="Format, validate, and minify"
    privacyNote="JSON parsing runs locally in your browser tab."
  >
    <div class="flex flex-wrap gap-2 mb-3">
      <button onclick="formatJSON()" class="tb-btn tb-btn-primary">Format / Beautify</button>
      <button onclick="minifyJSON()" class="tb-btn tb-btn-primary">Minify</button>
      <button onclick="clearJSON()" class="tb-btn tb-btn-outline">Clear</button>
      <button
        id="copyBtn"
        onclick="copyJSON()"
        class="tb-btn tb-btn-neutral bg-gray-800 dark:bg-gray-700 hover:bg-gray-900 dark:hover:bg-gray-700"
      >
        Copy Code
      </button>
    </div>
    <textarea
      id="jsonInput"
      class="tb-textarea tb-textarea-mono w-full h-96 font-mono resize-y"
      placeholder="Paste your JSON here..."
      spellcheck="false"
    ></textarea>
    <div id="jsonMessage" class="hidden mt-4 p-4 rounded-xl font-medium"></div>
  </ToolInterfaceWrapper>
</ToolPageLayout>
