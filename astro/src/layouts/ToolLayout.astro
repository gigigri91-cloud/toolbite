---
import BaseLayout from "@/layouts/BaseLayout.astro";

export interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  toolScript?: string;
}

const { title, description, canonicalPath, toolScript } = Astro.props;
---

<BaseLayout title={title} description={description} canonicalPath={canonicalPath} rootPath="/">
  <slot />

  <Fragment slot="scripts">
    {toolScript && <script defer src={toolScript}></script>}
    <slot name="scripts" />
  </Fragment>
</BaseLayout>

<style>
  :global(.tb-tool-hero),
  :global(.tool-hero),
  :global(.tb-tool-header),
  :global(.tool-header) {
    background: #0e1520 !important;
    border: 1px solid #1a2235 !important;
  }
</style>
