---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { createGuideMetadata } from "@/lib/seo";
import type { JsonLdObject } from "@/lib/schema";

export interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  keywords?: string[];
  schemas?: JsonLdObject[];
}

const { title, description, canonicalPath, keywords = [], schemas = [] } = Astro.props;
const metadata = createGuideMetadata({ title, description, canonicalPath, keywords });
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  rootPath="/"
  metadata={metadata}
  schemas={schemas}
  skipMainContainer
>
  <div class="guide-layout-prose">
    <slot />
    <div class="ad-slot ad-slot--article-end" aria-label="Advertisement">
      <!-- AdSense article end -->
    </div>
  </div>
</BaseLayout>
