---
import BaseLayout from "@/layouts/BaseLayout.astro";

export interface Props {
  title: string;
  description: string;
  canonicalPath: string;
}

const { title, description, canonicalPath } = Astro.props;
---

<BaseLayout title={title} description={description} canonicalPath={canonicalPath} rootPath="/">
  <slot />
  <Fragment slot="head">
    <slot name="head" />
  </Fragment>
</BaseLayout>
