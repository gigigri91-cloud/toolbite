---
export interface Props {
  rootPath?: string;
}

const { rootPath = "/" } = Astro.props;
---

<header id="site-header" class="tb-shell-header">
  <div class="tb-shell-container">
    <a href={`${rootPath}`} class="tb-brand-link" aria-label="ToolBite home">
      <span class="tb-brand-dot" aria-hidden="true"></span>
      <span>ToolBite</span>
    </a>
    <nav aria-label="Primary" class="tb-desktop-nav">
      <a href={`${rootPath}search.html`}>Search</a>
      <a href={`${rootPath}categories/text-tools.html`}>Categories</a>
      <a href={`${rootPath}guides/index.html`}>Guides</a>
      <a href={`${rootPath}contact.html`}>Contact</a>
    </nav>
    <button type="button" id="theme-toggle" class="theme-toggle-btn" aria-label="Toggle theme"></button>
    <button type="button" id="mobile-menu-button" class="tb-menu-toggle" aria-controls="mobile-menu" aria-expanded="false" aria-label="Open menu">
      Menu
    </button>
  </div>
</header>

<style>
  /* Sticky, blurred shell header to mirror the legacy `sticky bg-white/90`
     shell across the hybrid site so visitors don't see two different
     headers when crossing migrated/legacy pages. */
  .tb-shell-header {
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: saturate(140%) blur(8px);
    -webkit-backdrop-filter: saturate(140%) blur(8px);
    border-bottom: 1px solid var(--color-border-subtle);
    position: sticky;
    top: 0;
    z-index: 50;
    box-shadow: 0 1px 0 rgba(15, 23, 42, 0.04);
  }
  html[data-theme="dark"] .tb-shell-header {
    background: rgba(15, 23, 42, 0.85);
    border-bottom-color: var(--color-border-strong);
  }
  .tb-shell-container { max-width: 1200px; margin: 0 auto; padding: var(--space-3) var(--space-5); display: flex; align-items: center; justify-content: space-between; gap: var(--space-4); }
  .tb-brand-link { color: var(--color-text-primary); text-decoration: none; font-size: var(--text-lg); font-weight: 700; display: inline-flex; align-items: center; gap: var(--space-2); }
  .tb-brand-dot { width: 10px; height: 10px; border-radius: var(--radius-full); background: var(--color-brand-primary); }
  .tb-desktop-nav { display: none; gap: var(--space-4); }
  .tb-desktop-nav a { color: var(--color-text-secondary); text-decoration: none; font-size: var(--text-sm); }
  .tb-menu-toggle { border: 1px solid var(--color-border-strong); border-radius: var(--radius-md); padding: var(--space-2) var(--space-3); background: var(--color-bg-surface); color: var(--color-text-primary); }
  .theme-toggle-btn {
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-md);
    padding: var(--space-2);
    background: var(--color-bg-surface);
    color: var(--color-text-primary);
    line-height: 1;
    /* Visible on every breakpoint to match the legacy shell. */
  }
  @media (min-width: 768px) {
    .tb-desktop-nav { display: inline-flex; }
    .tb-menu-toggle { display: none; }
  }
</style>
