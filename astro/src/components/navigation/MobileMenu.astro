---
export interface Props {
  rootPath?: string;
}

const { rootPath = "/" } = Astro.props;
---

<nav id="mobile-menu" aria-hidden="true" class="tb-mobile-menu hidden">
  <a href={`${rootPath}search.html`}>Search</a>
  <a href={`${rootPath}categories/text-tools.html`}>Categories</a>
  <a href={`${rootPath}guides/index.html`}>Guides</a>
  <a href={`${rootPath}contact.html`}>Contact</a>
</nav>

<style>
  .tb-mobile-menu { border-bottom: 1px solid var(--color-border-subtle); background: var(--color-bg-surface); padding: 0 var(--space-5) var(--space-4); gap: var(--space-3); }
  .tb-mobile-menu.hidden { display: none; }
  .tb-mobile-menu:not(.hidden) { display: grid; }
  .tb-mobile-menu a { color: var(--color-text-secondary); text-decoration: none; font-size: var(--text-sm); }
  @media (min-width: 768px) {
    .tb-mobile-menu { display: none !important; }
  }
</style>
