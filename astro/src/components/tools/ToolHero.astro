---
export interface Props {
  title: string;
  description: string;
  eyebrow?: string;
}

const { title, description, eyebrow } = Astro.props;
---

<section class="tb-card tb-card-panel tb-card-pad-lg tb-tool-hero">
  {eyebrow && <p class="tb-tool-hero__eyebrow">{eyebrow}</p>}
  <h1 class="tb-tool-hero__title">{title}</h1>
  <p class="tb-tool-hero__desc">{description}</p>
</section>

<style>
  .tb-tool-hero {
    margin-bottom: 1.25rem;
    background: #0e1520;
    border: 1px solid #1a2235;
  }
  .tb-tool-hero__eyebrow {
    margin: 0 0 0.625rem;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(147 197 253);
    font-weight: 700;
  }
  .tb-tool-hero__title {
    margin: 0;
    font-size: clamp(1.8rem, 2vw + 1.2rem, 2.7rem);
    line-height: 1.1;
    font-weight: 800;
    color: rgb(243 244 246);
  }
  .tb-tool-hero__desc {
    margin: 0.9rem 0 0;
    max-width: 60ch;
    color: rgb(209 213 219);
    font-size: 1.02rem;
    line-height: 1.65;
  }
</style>
