---
export interface Props {
  title: string;
  description: string;
  eyebrow?: string;
  /** Hex accent for left border + eyebrow (per-tool WOW palette). */
  toolColor?: string;
}

const { title, description, eyebrow, toolColor = "#4d9fff" } = Astro.props;
const heroStyle = [
  "background:#090e18",
  "border:1px solid #1a2535",
  `border-left:3px solid ${toolColor}`
].join(";");
---

<section class="tb-tool-hero tb-card tb-card-panel tb-card-pad-lg" style={heroStyle}>
  {eyebrow && <p class="tb-tool-hero__eyebrow" style={`color: ${toolColor};`}>{eyebrow}</p>}
  <h1 class="tb-tool-hero__title">{title}</h1>
  <p class="tb-tool-hero__desc">{description}</p>
</section>

<style>
  .tb-tool-hero {
    margin-bottom: 1.25rem;
  }
  .tb-tool-hero__eyebrow {
    margin: 0 0 0.625rem;
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-family: var(--font-mono);
    font-weight: 600;
  }
  .tb-tool-hero__title {
    margin: 0;
    font-size: clamp(1.8rem, 2vw + 1.2rem, 2.7rem);
    line-height: 1.1;
    font-weight: 800;
    color: #ffffff;
  }
  .tb-tool-hero__desc {
    margin: 0.9rem 0 0;
    max-width: 60ch;
    color: #7a9ab8;
    font-size: 16px;
    line-height: 1.65;
  }
</style>
