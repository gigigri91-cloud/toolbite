---
export interface Props {
  examples: Array<{ title: string; input: string; output: string }>;
}
const { examples } = Astro.props;
---

<section class="tb-card tb-card-panel tb-card-pad-lg tb-tool-section">
  <h2 class="tb-tool-section__title">Practical examples</h2>
  <div class="tb-tool-example-grid">
    {examples.map((example) => (
      <article class="tb-card tb-card-pad-md tb-tool-example-item">
        <h3>{example.title}</h3>
        <p><strong>Input:</strong> {example.input}</p>
        <p><strong>Output:</strong> {example.output}</p>
      </article>
    ))}
  </div>
</section>

<style>
  .tb-tool-example-grid {
    display: grid;
    gap: 0.75rem;
  }
  .tb-tool-example-item h3 {
    margin: 0 0 0.5rem;
    font-size: 0.95rem;
    color: rgb(17 24 39);
  }
  .tb-tool-example-item p {
    margin: 0.3rem 0;
    color: rgb(75 85 99);
    font-size: 0.875rem;
    line-height: 1.5;
  }
  html[data-theme="dark"] .tb-tool-example-item h3 {
    color: rgb(243 244 246);
  }
  html[data-theme="dark"] .tb-tool-example-item p {
    color: rgb(209 213 219);
  }
</style>
