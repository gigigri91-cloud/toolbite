---
// Renders a real AdSense slot only when a non-empty `slotId` is provided.
// When no slot id is configured, render NOTHING — never emit an ad-labeled
// container without an ad. Auto Ads (loader script in BaseLayout) is the
// monetization path until governed slot IDs exist.
export interface Props {
  slotId?: string;
  label?: string;
}

const { slotId = "", label = "Advertisement" } = Astro.props;
const trimmedSlot = String(slotId || "").trim();
const hasSlot = trimmedSlot.length > 0;
---

{hasSlot && (
  <section class="tb-card tb-card-panel tb-card-pad-md tb-tool-ad" aria-label={label}>
    <p class="tb-tool-ad__label">{label}</p>
    <div class="tb-tool-ad__frame">
      <ins
        class="adsbygoogle"
        style="display:block"
        data-ad-client="ca-pub-5233222002046639"
        data-ad-slot={trimmedSlot}
        data-ad-format="auto"
        data-full-width-responsive="true"
      ></ins>
    </div>
  </section>
)}

<style>
  .tb-tool-ad {
    margin-bottom: 1.25rem;
  }
  .tb-tool-ad__label {
    margin: 0 0 0.6rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(107 114 128);
  }
  .tb-tool-ad__frame {
    min-height: 280px;
  }
  html[data-theme="dark"] .tb-tool-ad__label {
    color: rgb(156 163 175);
  }
</style>
