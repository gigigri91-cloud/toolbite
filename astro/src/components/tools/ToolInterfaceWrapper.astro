---
export interface Props {
  title?: string;
  privacyNote?: string;
}

const { title = "Use the tool", privacyNote } = Astro.props;
---

<section class="tb-tool-interface-wrapper">
  <header class="tb-tool-interface-wrapper__head">
    <h2 class="tb-tool-interface-wrapper__title">{title}</h2>
    {privacyNote && <p class="tb-tool-interface-wrapper__privacy">{privacyNote}</p>}
  </header>
  <slot />
</section>

<style>
  .tb-tool-interface-wrapper {
    margin-bottom: 1.5rem;
    background: #090e18;
    border: 1px solid #1a2535;
    border-radius: 10px;
    padding: 1.25rem 1.35rem;
  }
  .tb-tool-interface-wrapper__head {
    margin-bottom: 1rem;
  }
  .tb-tool-interface-wrapper__title {
    margin: 0;
    font-size: 17px;
    font-weight: 700;
    color: #ffffff;
  }
  .tb-tool-interface-wrapper__privacy {
    margin: 0.5rem 0 0;
    font-size: 0.9rem;
    color: #7a9ab8;
  }
  .tb-tool-interface-wrapper :global(textarea.tb-textarea) {
    background: #06080d !important;
    border: 1px solid #1e2a3a !important;
    color: #c8dff5 !important;
  }
</style>
