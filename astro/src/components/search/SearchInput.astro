---
export interface Props {
  id?: string;
  placeholder?: string;
  hotkeyLabel?: string;
}

const { id = "search-input", placeholder = "Search tools, guides, or keywords...", hotkeyLabel = "/" } = Astro.props;
---

<div class="search-input-wrap">
  <label for={id} class="sr-only">Search tools</label>
  <span class="search-prompt" aria-hidden="true">~$</span>
  <input id={id} type="search" placeholder={placeholder} autocomplete="off" />
  <kbd aria-hidden="true">{hotkeyLabel}</kbd>
</div>

<style>
  .search-input-wrap {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid var(--color-border-secondary);
    border-radius: 0.75rem;
    background: var(--color-bg-card);
    padding: 0.5rem 0.75rem;
  }
  .search-prompt {
    color: var(--color-brand-orange);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    line-height: 1;
  }
  input[type="search"] {
    border: 0;
    outline: 0;
    background: transparent;
    color: var(--color-text-primary);
    font-size: 1rem;
    width: 100%;
  }
  input[type="search"]::placeholder { color: var(--color-text-muted); }
  kbd {
    border: 1px solid var(--color-border-primary);
    border-radius: 0.4rem;
    padding: 0.1rem 0.4rem;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    background: #0d1e35;
    font-family: var(--font-mono);
  }
</style>
