---
import BreadcrumbJsonLd from "@/components/seo/BreadcrumbJsonLd.astro";
import CategoryHighlights from "@/components/discovery/CategoryHighlights.astro";
import DiscoverySection from "@/components/discovery/DiscoverySection.astro";
import PopularToolsSection from "@/components/discovery/PopularToolsSection.astro";
import RecentlyAddedSection from "@/components/discovery/RecentlyAddedSection.astro";
import RecommendedToolsSection from "@/components/discovery/RecommendedToolsSection.astro";
import TrendingToolsSection from "@/components/discovery/TrendingToolsSection.astro";
import { getAllTools, getCategoryTools } from "@/lib/tools";

export interface Props {
  slug: string;
  title: string;
  heroDescription: string;
}

const { slug, title, heroDescription } = Astro.props;
const tools = getCategoryTools(slug);
const featured = tools.slice(0, 4);
const popularInCategory = [...tools].sort((a, b) => (b.keywords.length + (b.relatedTools?.length || 0)) - (a.keywords.length + (a.relatedTools?.length || 0))).slice(0, 4);
const recentInCategory = [...tools].slice(-4).reverse();

const all = getAllTools();
const related = all
  .filter((tool) => tool.category !== slug && tool.keywords.some((k) => tools.some((t) => t.keywords.includes(k))))
  .slice(0, 4);

---

<CategoryHighlights categorySlug={slug} categoryTitle={title} heroDescription={heroDescription} featuredTools={featured} />

<section class="tb-card tb-card-panel tb-card-pad-lg mb-6">
  <div class="search-row">
    <input id="category-search" type="search" class="tb-input w-full sm:w-96 border" placeholder="Filter tools in this category..." aria-label={`Filter ${title}`} />
    <button type="button" class="copy-tool-link tb-btn tb-btn-secondary">Copy page link</button>
  </div>
  <div id="category-tools-grid" class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
    {tools.map((tool) => (
      <a href={`/${tool.url}`} class="tb-card tb-card-interactive tb-card-pad-lg tb-card-row">
        <div class="tb-tool-icon tb-icon-blue">{tool.icon || "🧰"}</div>
        <div>
          <h3 class="font-bold text-gray-900 dark:text-gray-100 text-lg">{tool.title}</h3>
          <p class="text-sm text-gray-500 dark:text-gray-400">{tool.description}</p>
        </div>
      </a>
    ))}
  </div>
</section>

<DiscoverySection title="Popular in this category" subtitle="Most reused workflows in this category." tools={popularInCategory} />
<DiscoverySection title="Recently added in this category" subtitle="Fresh additions for your workflow stack." tools={recentInCategory} />
<DiscoverySection title="Related from other categories" subtitle="Cross-category tools with high contextual overlap." tools={related} />
<TrendingToolsSection />
<PopularToolsSection />
<RecentlyAddedSection />
<RecommendedToolsSection />

<BreadcrumbJsonLd
  items={[
    { name: "Home", url: "https://toolbite.org/" },
    { name: "Categories", url: "https://toolbite.org/categories/" },
    { name: title, url: `https://toolbite.org/categories/${slug}.html` }
  ]}
/>

<style>
  .search-row { display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center; }
</style>
