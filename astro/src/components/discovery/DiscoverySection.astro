---
import ToolCard from "@/components/discovery/ToolCard.astro";
import type { NormalizedTool } from "@/lib/tools";

export interface Props {
  title: string;
  subtitle?: string;
  tools: NormalizedTool[];
}

const { title, subtitle, tools } = Astro.props;
---

<section class="tb-card tb-card-panel tb-card-pad-lg discovery-section">
  <div class="discovery-header">
    <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100">{title}</h2>
    {subtitle && <p class="text-sm text-gray-600 dark:text-gray-400">{subtitle}</p>}
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {tools.map((tool) => <ToolCard tool={tool} />)}
  </div>
</section>

<style>
  .discovery-section { margin-bottom: 1.5rem; }
  .discovery-header { margin-bottom: 1rem; }
</style>
