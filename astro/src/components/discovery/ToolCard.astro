---
import type { NormalizedTool } from "@/lib/tools";
import { CATEGORY_COLORS, getToolAccentFromUrl, toolSlugFromUrl } from "@/lib/wow-colors";

export interface Props {
  tool: NormalizedTool;
  /** Optional override for accent (hex). Defaults from tool URL slug map. */
  toolColor?: string;
}

const { tool, toolColor } = Astro.props;
const href = `/${tool.url}`;
const slug = toolSlugFromUrl(tool.url);
const accent = toolColor ?? getToolAccentFromUrl(tool.url);
const categoryHex = CATEGORY_COLORS[tool.category] ?? "#4d9fff";
const categoryLabel = tool.category?.replace(/-/g, " ") ?? "tool";

const cardStyle = [
  "background:#090e18",
  "border:1px solid #1a2535",
  `border-top:2px solid ${accent}`,
  "border-radius:10px"
].join(";");
---

<a
  href={href}
  class="wow-tool-card tb-card-interactive discovery-card"
  style={cardStyle}
  data-tool-slug={slug}
>
  <div class="wow-tool-card__icon" style={`--wow-tool-accent: ${accent};`} aria-hidden="true">{tool.icon || "🧰"}</div>
  <div class="wow-tool-card__body">
    {tool.category && (
      <p class="wow-tool-card__category" style={`color: ${categoryHex};`}>
        // {categoryLabel}
      </p>
    )}
    <h3 class="wow-tool-card__title">{tool.title}</h3>
    <p class="wow-tool-card__desc">{tool.description}</p>
  </div>
</a>

<style>
  .wow-tool-card {
    --wow-tool-accent: #4d9fff;
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 0.85rem;
    padding: 1rem 1.15rem;
    text-decoration: none;
    transition: box-shadow 180ms ease, transform 180ms ease, filter 180ms ease;
  }
  .wow-tool-card:hover {
    box-shadow: 0 0 0 1px rgba(77, 159, 255, 0.2);
    transform: translateY(-2px);
  }
  .wow-tool-card__icon {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 8px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    background: color-mix(in srgb, var(--wow-tool-accent) 18%, transparent);
    border: 1px solid color-mix(in srgb, var(--wow-tool-accent) 35%, transparent);
    flex-shrink: 0;
  }
  .wow-tool-card__body {
    min-width: 0;
  }
  .wow-tool-card__category {
    margin: 0 0 0.35rem;
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: lowercase;
    letter-spacing: 0.04em;
  }
  .wow-tool-card__title {
    margin: 0;
    color: #c8dff5;
    font-weight: 700;
    font-size: 14px;
    line-height: 1.35;
  }
  .wow-tool-card__desc {
    margin: 0.35rem 0 0;
    font-size: 14px;
    line-height: 1.5;
    color: #7a9ab8;
  }
  @media (prefers-reduced-motion: reduce) {
    .wow-tool-card {
      transition: none;
    }
    .wow-tool-card:hover {
      transform: none;
    }
  }
</style>
