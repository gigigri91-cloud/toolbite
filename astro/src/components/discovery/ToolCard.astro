---
import type { NormalizedTool } from "@/lib/tools";

export interface Props {
  tool: NormalizedTool;
}

const { tool } = Astro.props;
const href = `/${tool.url}`;
---

<a href={href} class="tb-card tb-card-interactive tb-card-pad-lg tb-card-row discovery-card">
  <div class="tb-tool-icon tb-icon-blue">{tool.icon || "🧰"}</div>
  <div>
    {tool.category && <p class="tool-category">// {tool.category}</p>}
    <h3 class="font-bold text-lg tool-title">{tool.title}</h3>
    <p class="text-sm text-gray-500 dark:text-gray-400">{tool.description}</p>
  </div>
</a>

<style>
  .discovery-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-secondary);
    border-top: 2px solid var(--color-border-accent-blue);
    border-radius: 8px;
  }
  .tool-title {
    color: var(--color-text-accent-blue);
  }
  .tool-category {
    margin: 0 0 0.35rem;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    font-size: 0.72rem;
    text-transform: lowercase;
  }
</style>
