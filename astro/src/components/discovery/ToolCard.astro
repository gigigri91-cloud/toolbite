---
import type { NormalizedTool } from "@/lib/tools";

export interface Props {
  tool: NormalizedTool;
}

const { tool } = Astro.props;
const href = `/${tool.url}`;
---

<a href={href} class="tb-card tb-card-interactive tb-card-pad-lg tb-card-row discovery-card">
  <div class="tb-tool-icon tb-icon-blue">{tool.icon || "🧰"}</div>
  <div>
    <h3 class="font-bold text-gray-900 dark:text-gray-100 text-lg">{tool.title}</h3>
    <p class="text-sm text-gray-500 dark:text-gray-400">{tool.description}</p>
  </div>
</a>

<style>
  .discovery-card {
    background: linear-gradient(180deg, rgba(37, 99, 235, 0.05), rgba(15, 23, 42, 0.01));
    border: 1px solid rgba(148, 163, 184, 0.22);
    backdrop-filter: blur(4px);
  }
  html[data-theme="dark"] .discovery-card {
    background: linear-gradient(180deg, rgba(96, 165, 250, 0.12), rgba(15, 23, 42, 0.35));
    border-color: rgba(96, 165, 250, 0.24);
    box-shadow: 0 0 0 1px rgba(59, 130, 246, 0.12), 0 10px 30px rgba(2, 6, 23, 0.4);
  }
</style>
