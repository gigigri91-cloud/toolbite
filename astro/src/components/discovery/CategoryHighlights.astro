---
import type { NormalizedTool } from "@/lib/tools";
import { getCategoryRelatedCategories } from "@/lib/tools";

export interface Props {
  categorySlug: string;
  categoryTitle: string;
  heroDescription: string;
  featuredTools: NormalizedTool[];
}

const { categorySlug, categoryTitle, heroDescription, featuredTools } = Astro.props;
const relatedCategories = getCategoryRelatedCategories(categorySlug);
---

<section class="category-hero tb-card tb-card-panel tb-card-pad-lg">
  <p class="category-kicker">Productivity ecosystem</p>
  <h1 class="text-4xl font-extrabold mb-2">{categoryTitle}</h1>
  <p class="text-lg max-w-3xl">{heroDescription}</p>
  <div class="hero-grid">
    {featuredTools.map((tool) => (
      <a href={`/${tool.url}`} class="feature-chip">
        <span>{tool.icon || "🧰"}</span>
        <span>{tool.title}</span>
      </a>
    ))}
  </div>
  <div class="related-cats">
    {relatedCategories.map((cat) => (
      <a href={`/categories/${cat}.html`} class="cat-link">{cat.replace("-", " ")}</a>
    ))}
  </div>
</section>

<style>
  .category-hero {
    margin-bottom: 1.5rem;
    background:
      radial-gradient(80% 120% at 90% -10%, rgba(59, 130, 246, 0.2), transparent 60%),
      linear-gradient(180deg, color-mix(in srgb, var(--color-brand-blue) 16%, transparent), transparent 62%),
      var(--color-bg-card);
    border: 1px solid var(--color-border-secondary);
  }
  .category-kicker { text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.75rem; color: var(--color-brand-blue-dark); font-weight: 700; margin-bottom: 0.5rem; }
  .category-hero h1 { color: var(--color-text-primary); }
  .category-hero p { color: var(--color-text-secondary); }
  .hero-grid { display: grid; gap: 0.75rem; margin-top: 1rem; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); }
  .feature-chip {
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--color-border-secondary);
    border-radius: 0.75rem;
    padding: 0.75rem 1rem;
    background: var(--color-bg-card);
    display: inline-flex;
    gap: 0.5rem;
    align-items: center;
    transition: transform 180ms ease, border-color 180ms ease;
  }
  .feature-chip:hover { transform: translateY(-2px); border-color: var(--color-border-accent-blue); }
  .related-cats { margin-top: 1rem; display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .cat-link {
    text-decoration: none;
    color: var(--color-text-secondary);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-secondary);
    border-radius: 9999px;
    padding: 0.35rem 0.8rem;
    font-size: 0.875rem;
    text-transform: capitalize;
  }
  .cat-link:hover { color: var(--color-brand-blue); border-color: var(--color-border-accent-blue); }
</style>
