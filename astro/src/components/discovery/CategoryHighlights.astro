---
import type { NormalizedTool } from "@/lib/tools";
import { getCategoryAccent, hexToRgb } from "@/lib/wow-colors";

export interface Props {
  categorySlug: string;
  categoryTitle: string;
  heroDescription: string;
  featuredTools: NormalizedTool[];
}

const { categorySlug, categoryTitle, heroDescription, featuredTools } = Astro.props;

const CATEGORY_TABS = [
  { slug: "developer-tools", label: "Developer Tools" },
  { slug: "text-tools", label: "Text Tools" },
  { slug: "image-tools", label: "Image Tools" },
  { slug: "seo-tools", label: "SEO Tools" }
] as const;

const TAB_THEME: Record<string, { color: string; border: string; bg: string }> = {
  "developer-tools": {
    color: "#4d9fff",
    border: "rgba(77,159,255,0.3)",
    bg: "rgba(13,30,53,0.5)"
  },
  "text-tools": {
    color: "#a855f7",
    border: "rgba(168,85,247,0.3)",
    bg: "rgba(20,5,40,0.5)"
  },
  "image-tools": {
    color: "#2dd4bf",
    border: "rgba(45,212,191,0.3)",
    bg: "rgba(5,25,25,0.5)"
  },
  "seo-tools": {
    color: "#f5a623",
    border: "rgba(245,166,35,0.3)",
    bg: "rgba(30,15,0,0.5)"
  }
};

const accent = getCategoryAccent(categorySlug);
const { r, g, b } = hexToRgb(accent);
const tintBg = `rgba(${r}, ${g}, ${b}, 0.08)`;
const tintBorder = `rgba(${r}, ${g}, ${b}, 0.2)`;
const tintStrong = `rgba(${r}, ${g}, ${b}, 0.35)`;
const chipBg = `rgba(${r}, ${g}, ${b}, 0.12)`;
---

<section
  class="category-hero tb-card tb-card-panel tb-card-pad-lg"
  style={`--cat-accent: ${accent}; background: radial-gradient(80% 120% at 90% -10%, ${tintStrong}, transparent 55%), ${tintBg}; border: 1px solid ${tintBorder};`}
>
  <p class="category-kicker" style={`color: ${accent};`}>Productivity ecosystem</p>
  <h1 class="category-title">{categoryTitle}</h1>
  <p class="category-desc">{heroDescription}</p>
  <div class="hero-grid">
    {featuredTools.map((tool) => (
      <a href={`/${tool.url}`} class="feature-chip" style={`border-color: ${tintBorder}; background: ${chipBg};`}>
        <span class="feature-chip__icon" style={`color: ${accent}; background: rgba(${r},${g},${b},0.18);`}>{tool.icon || "🧰"}</span>
        <span class="feature-chip__label">{tool.title}</span>
      </a>
    ))}
  </div>
  <nav class="related-cats" aria-label="Browse categories">
    {CATEGORY_TABS.map((tab) => {
      const theme = TAB_THEME[tab.slug];
      const isActive = tab.slug === categorySlug;
      return (
        <a
          href={`/categories/${tab.slug}.html`}
          class:list={["cat-tab", { "cat-tab--active": isActive }]}
          style={`color: ${theme.color}; border: 1px solid ${theme.border}; background: ${theme.bg};`}
          aria-current={isActive ? "page" : undefined}
        >
          {tab.label}
        </a>
      );
    })}
  </nav>
</section>

<style>
  .category-hero {
    margin-bottom: 1.5rem;
    border-radius: 10px;
  }
  .category-kicker {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.75rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  .category-title {
    margin: 0 0 0.35rem;
    font-size: clamp(1.85rem, 3vw, 2.4rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #ffffff;
  }
  .category-desc {
    margin: 0;
    max-width: 52ch;
    font-size: 16px;
    line-height: 1.6;
    color: #7a9ab8;
  }
  .hero-grid {
    display: grid;
    gap: 0.75rem;
    margin-top: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  }
  .feature-chip {
    text-decoration: none;
    color: var(--text-primary, #fff);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    display: inline-flex;
    gap: 0.5rem;
    align-items: center;
    border: 1px solid transparent;
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }
  .feature-chip:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
    border-color: color-mix(in srgb, var(--cat-accent) 50%, #ffffff 50%);
  }
  .feature-chip__icon {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 8px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    flex-shrink: 0;
  }
  .feature-chip__label {
    font-weight: 600;
    font-size: 0.9rem;
    color: #c8dff5;
  }
  .related-cats {
    margin-top: 1rem;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    align-items: center;
  }
  .cat-tab {
    text-decoration: none;
    border-radius: 20px;
    padding: 0.45rem 1rem;
    font-size: 13px;
    font-weight: 600;
    transition: filter 160ms ease, transform 160ms ease;
  }
  .cat-tab:hover {
    filter: brightness(1.1);
  }
  .cat-tab--active {
    box-shadow: 0 0 0 1px currentColor;
  }
  @media (prefers-reduced-motion: reduce) {
    .feature-chip {
      transition: none;
    }
    .feature-chip:hover {
      transform: none;
    }
    .cat-tab {
      transition: none;
    }
  }
</style>
