---
import type { NormalizedTool } from "@/lib/tools";
import { getCategoryRelatedCategories } from "@/lib/tools";

export interface Props {
  categorySlug: string;
  categoryTitle: string;
  heroDescription: string;
  featuredTools: NormalizedTool[];
}

const { categorySlug, categoryTitle, heroDescription, featuredTools } = Astro.props;
const relatedCategories = getCategoryRelatedCategories(categorySlug);
---

<section class="category-hero tb-card tb-card-panel tb-card-pad-lg">
  <p class="category-kicker">Productivity ecosystem</p>
  <h1 class="text-4xl font-extrabold text-gray-900 dark:text-gray-100 mb-2">{categoryTitle}</h1>
  <p class="text-lg text-gray-600 dark:text-gray-400 max-w-3xl">{heroDescription}</p>
  <div class="hero-grid">
    {featuredTools.map((tool) => (
      <a href={`/${tool.url}`} class="feature-chip">
        <span>{tool.icon || "🧰"}</span>
        <span>{tool.title}</span>
      </a>
    ))}
  </div>
  <div class="related-cats">
    {relatedCategories.map((cat) => (
      <a href={`/categories/${cat}.html`} class="cat-link">{cat.replace("-", " ")}</a>
    ))}
  </div>
</section>

<style>
  .category-hero {
    margin-bottom: 1.5rem;
    background:
      radial-gradient(80% 120% at 90% -10%, rgba(59, 130, 246, 0.2), transparent 60%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(248, 250, 252, 0.95));
    border: 1px solid rgba(148, 163, 184, 0.25);
  }
  html[data-theme="dark"] .category-hero {
    background:
      radial-gradient(80% 120% at 90% -10%, rgba(56, 189, 248, 0.25), transparent 60%),
      linear-gradient(180deg, rgba(15, 23, 42, 0.9), rgba(30, 41, 59, 0.95));
    border-color: rgba(59, 130, 246, 0.25);
    box-shadow: 0 0 0 1px rgba(56, 189, 248, 0.12), 0 20px 40px rgba(2, 6, 23, 0.45);
  }
  .category-kicker { text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.75rem; color: #2563eb; font-weight: 700; margin-bottom: 0.5rem; }
  html[data-theme="dark"] .category-kicker { color: #7dd3fc; }
  .hero-grid { display: grid; gap: 0.75rem; margin-top: 1rem; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); }
  .feature-chip {
    text-decoration: none;
    color: inherit;
    border: 1px solid rgba(148, 163, 184, 0.3);
    border-radius: 0.75rem;
    padding: 0.75rem 1rem;
    background: rgba(255, 255, 255, 0.6);
    display: inline-flex;
    gap: 0.5rem;
    align-items: center;
    transition: transform 180ms ease, border-color 180ms ease;
  }
  html[data-theme="dark"] .feature-chip {
    background: rgba(15, 23, 42, 0.45);
    border-color: rgba(96, 165, 250, 0.3);
  }
  .feature-chip:hover { transform: translateY(-2px); border-color: rgba(37, 99, 235, 0.45); }
  .related-cats { margin-top: 1rem; display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .cat-link {
    text-decoration: none;
    color: #334155;
    background: #f8fafc;
    border: 1px solid #cbd5e1;
    border-radius: 9999px;
    padding: 0.35rem 0.8rem;
    font-size: 0.875rem;
    text-transform: capitalize;
  }
  html[data-theme="dark"] .cat-link { color: #e2e8f0; background: #1e293b; border-color: #475569; }
</style>
