---
export interface Props {
  rootPath?: string;
}

const { rootPath = "/" } = Astro.props;
---

<footer id="site-footer" class="tb-shell-footer">
  <div class="tb-shell-container">
    <p class="tb-footer-copy">
      &copy; <span id="current-year"></span> <span class="tb-footer-brand"><span class="tb-brand-tool">Tool</span><span class="tb-brand-bite">Bite</span></span>.org. All rights reserved.
    </p>
    <nav class="tb-footer-nav" aria-label="Footer">
      <a href={`${rootPath}about.html`}>About</a>
      <a href={`${rootPath}contact.html`}>Contact</a>
      <a href="/guides/">Guides</a>
      <a href={`${rootPath}editorial-policy.html`}>Editorial</a>
      <a href={`${rootPath}privacy.html`}>Privacy</a>
      <a href={`${rootPath}cookie-policy.html`}>Cookies</a>
      <a href={`${rootPath}terms.html`}>Terms</a>
      <a
        href={`${rootPath}privacy.html#ads`}
        data-open-cookie-settings="true"
        aria-label="Manage cookie preferences"
      >Manage cookies</a>
    </nav>
  </div>
</footer>

<style>
  .tb-shell-footer { border-top: 1px solid var(--color-border-primary); margin-top: 3rem; background: var(--color-bg-secondary); }
  .tb-shell-footer .tb-shell-container { max-width: 1200px; margin: 0 auto; padding: 1.5rem 1.25rem; display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 0.75rem; }
  .tb-footer-copy { margin: 0; color: var(--color-text-muted); font-size: 0.875rem; }
  .tb-footer-brand { font-weight: 700; }
  .tb-brand-tool { color: #e8f0ff; }
  .tb-brand-bite { color: var(--color-brand-orange); }
  .tb-footer-nav { display: inline-flex; flex-wrap: wrap; gap: 1rem; }
  .tb-footer-nav a { color: var(--color-text-muted); text-decoration: none; font-size: 0.875rem; }
  .tb-footer-nav a:hover { color: var(--color-brand-blue); }
</style>
